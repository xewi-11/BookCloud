@using Microsoft.CodeAnalysis.Differencing
@model List<Pedido>

@{
    ViewData["Title"] = "Mis Pedidos";
}

<div class="pedidos-container">
    <h1 class="section-title">
        <i class="bi bi-box-seam"></i> Mis Pedidos
    </h1>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <h3>No tienes pedidos aún</h3>
            <p>Cuando realices una compra, tus pedidos aparecerán aquí.</p>
            <a asp-controller="Libro" asp-action="Index" class="btn btn-primary mt-3">
                <i class="bi bi-book"></i> Explorar Libros
            </a>
        </div>
    }
    else
    {
        @foreach (var pedido in Model.OrderByDescending(p => p.FechaPedido))
        {
            <div class="pedido-card animate-fade-in">
                <div class="pedido-header">
                    <div>
                        <i class="bi bi-receipt"></i>
                        <strong>Pedido #@pedido.Id</strong>
                        <span class="text-muted ms-2">
                            @pedido.FechaPedido.ToString("dd/MM/yyyy HH:mm")
                        </span>
                    </div>
                    <div>
                        @if (pedido.Estado == "Completado")
                        {
                            <span class="badge bg-success">
                                <i class="bi bi-check-circle"></i> @pedido.Estado
                            </span>
                        }
                        else if (pedido.Estado == "Pendiente")
                        {
                            <span class="badge bg-warning">
                                <i class="bi bi-clock"></i> @pedido.Estado
                            </span>
                        }
                        else if (pedido.Estado == "Cancelado")
                        {
                            <span class="badge bg-danger">
                                <i class="bi bi-x-circle"></i> @pedido.Estado
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@pedido.Estado</span>
                        }
                    </div>
                </div>
                <div class="pedido-body">
                    @if (pedido.PedidoDetalles != null && pedido.PedidoDetalles.Any())
                    {
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Libro</th>
                                        <th>Autor</th>
                                        <th class="text-center">Cantidad</th>
                                        <th class="text-end">Precio Unit.</th>
                                        <th class="text-end">Subtotal</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var detalle in pedido.PedidoDetalles.Where(d => d.Activo))
                                    {
                                        <tr>
                                            <td>
                                                @if (detalle.Libro != null)
                                                {
                                                    <div class="d-flex align-items-center gap-3">
                                                        @if (!string.IsNullOrEmpty(detalle.Libro.Foto))
                                                        {
                                                            <img src="~/imagenes/Libros/@detalle.Libro.Foto" 
                                                                 alt="@detalle.Libro.Titulo"
                                                                 class="libro-imagen" />
                                                        }
                                                        <strong>@detalle.Libro.Titulo</strong>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Libro no disponible</span>
                                                }
                                            </td>
                                            <td>
                                                @if (detalle.Libro != null)
                                                {
                                                    <span>@detalle.Libro.Autor</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <span class="badge" style="background: rgba(198, 167, 94, 0.2); color: var(--dorado);">
                                                    @detalle.Cantidad
                                                </span>
                                            </td>
                                            <td class="text-end">$@detalle.PrecioUnitario.ToString("N2")</td>
                                            <td class="text-end">
                                                <strong style="color: var(--dorado);">
                                                    $@((detalle.Cantidad * detalle.PrecioUnitario).ToString("N2"))
                                                </strong>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No hay detalles disponibles para este pedido.</p>
                    }

                    <hr style="border-color: rgba(198, 167, 94, 0.3);" />

                    <div class="row align-items-center">
                        <div class="col-md-6">
                            @if (pedido.Pagos != null && pedido.Pagos.Any())
                            {
                                var pago = pedido.Pagos.FirstOrDefault();
                                if (pago != null)
                                {
                                    <div class="metodo-pago">
                                        @if (pago.Metodo == "Wallet")
                                        {
                                            <i class="bi bi-wallet2" style="color: var(--dorado);"></i>
                                            <strong>Wallet</strong>
                                        }
                                        else if (pago.Metodo == "Tarjeta")
                                        {
                                            <i class="bi bi-credit-card" style="color: #3b82f6;"></i>
                                            <strong>Tarjeta</strong>
                                        }
                                        else
                                        {
                                            <strong>@pago.Metodo</strong>
                                        }
                                    </div>
                                }
                            }
                        </div>
                        <div class="col-md-6 text-end mt-3 mt-md-0">
                            <div class="d-inline-block text-start">
                                <small class="text-muted d-block">Total del pedido</small>
                                <span class="total-pedido">$@pedido.Total.ToString("N2")</span>
                            </div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <a asp-action="ConfirmacionPedido" 
                           asp-route-id="@pedido.Id" 
                           class="btn btn-outline-gold">
                            <i class="bi bi-eye"></i> Ver Detalles Completos
                        </a>
                    </div>
                </div>
            </div>
        }

        <!-- Resumen de pedidos -->
        <div class="resumen-card">
            <div class="row">
                <div class="col-md-4 resumen-stat stat-primary">
                    <h3>@Model.Count</h3>
                    <p>Total de Pedidos</p>
                </div>
                <div class="col-md-4 resumen-stat stat-success">
                    <h3>@Model.Count(p => p.Estado == "Completado")</h3>
                    <p>Completados</p>
                </div>
                <div class="col-md-4 resumen-stat stat-gold">
                    <h3>$@Model.Sum(p => p.Total).ToString("N2")</h3>
                    <p>Total Gastado</p>
                </div>
            </div>
        </div>
    }
</div>  

<style>
    .pedidos-container {
        max-width: 1200px;
        margin: 2rem auto;
    }

    .pedido-card {
        background: var(--verde-card);
        border: 2px solid var(--dorado);
        border-radius: 16px;
        margin-bottom: 2rem;
        overflow: hidden;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
        transition: all 0.3s ease;
    }

    .pedido-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(198, 167, 94, 0.5);
    }

    .pedido-header {
        background: linear-gradient(135deg, rgba(198, 167, 94, 0.2) 0%, rgba(19, 47, 40, 0.2) 100%);
        border-bottom: 2px solid var(--dorado);
        padding: 1.25rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .pedido-header strong {
        color: var(--dorado);
        font-size: 1.1rem;
    }

    .pedido-body {
        padding: 1.5rem;
    }

    .table {
        color: var(--texto-claro);
        margin-bottom: 0;
    }

    .table thead th {
        border-bottom: 2px solid var(--dorado);
        color: var(--dorado);
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.85rem;
        padding: 1rem 0.75rem;
        background: rgba(198, 167, 94, 0.1);
    }

    .table tbody td {
        border-bottom: 1px solid rgba(198, 167, 94, 0.2);
        padding: 1rem 0.75rem;
        vertical-align: middle;
    }

    .table tbody tr:last-child td {
        border-bottom: none;
    }

    .libro-imagen {
        width: 50px;
        height: 70px;
        object-fit: cover;
        border-radius: 6px;
        border: 2px solid var(--dorado);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    }

    .badge {
        padding: 0.5rem 1rem;
        font-size: 0.9rem;
        font-weight: 600;
        border-radius: 8px;
    }

    .badge.bg-success {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%) !important;
    }

    .badge.bg-warning {
        background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%) !important;
        color: var(--verde-fondo) !important;
    }

    .badge.bg-danger {
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%) !important;
    }

    .total-pedido {
        color: var(--dorado);
        font-size: 1.8rem;
        font-weight: 800;
    }

    .metodo-pago {
        background: rgba(198, 167, 94, 0.1);
        border-radius: 8px;
        padding: 0.75rem;
        display: inline-block;
    }

    .metodo-pago i {
        font-size: 1.2rem;
        margin-right: 0.5rem;
    }

    .resumen-card {
        background: var(--verde-card);
        border: 2px solid var(--dorado);
        border-radius: 16px;
        padding: 2rem;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
        margin-top: 2rem;
    }

    .resumen-stat {
        text-align: center;
        padding: 1.5rem;
    }

    .resumen-stat h3 {
        font-size: 2.5rem;
        font-weight: 800;
        margin-bottom: 0.5rem;
    }

    .resumen-stat p {
        color: var(--texto-secundario);
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin: 0;
    }

    .stat-primary h3 { color: #3b82f6; }
    .stat-success h3 { color: #10b981; }
    .stat-gold h3 { color: var(--dorado); }

    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        background: var(--verde-card);
        border: 2px solid var(--dorado);
        border-radius: 20px;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
    }

    .empty-state i {
        font-size: 5rem;
        color: var(--dorado);
        opacity: 0.3;
        margin-bottom: 1.5rem;
    }

    .empty-state h3 {
        color: var(--texto-claro);
        margin-bottom: 1rem;
    }

    .empty-state p {
        color: var(--texto-secundario);
        margin-bottom: 2rem;
    }

    @@media (max-width: 768px) {
        .table {
            font-size: 0.85rem;
        }

        .libro-imagen {
            width: 40px;
            height: 56px;
        }

        .pedido-header {
            flex-direction: column;
            gap: 1rem;
            text-align: center;
        }

        .resumen-stat h3 {
            font-size: 2rem;
        }
    }
</style>