@model List<Libro>

@{
    ViewData["Title"] = "Catálogo de Libros";
    var usuarioActualId = Context.Session.GetString("Id");
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="section-title mb-0">Catálogo de Libros</h1>
        @if (!string.IsNullOrEmpty(usuarioActualId))
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Nuevo Libro
            </a>
        }
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="book-grid">
            @foreach (var libro in Model)
            {
                var esPropio = libro.UsuarioId.ToString() == usuarioActualId;
                
                <div class="book-card animate-fade-in">
                    <div class="position-relative overflow-hidden">
                        <img src="~/imagenes/Libros/@libro.Foto" 
                             alt="@libro.Titulo" 
                             onerror="this.src='/images/default-book.jpg'"
                             class="book-card-image" />
                        @if (libro.Stock < 5 && libro.Stock > 0)
                        {
                            <span class="badge bg-warning position-absolute top-0 end-0 m-3">
                                ¡Últimas unidades!
                            </span>
                        }
                        @if (libro.Stock == 0)
                        {
                            <span class="badge bg-danger position-absolute top-0 end-0 m-3">
                                Agotado
                            </span>
                        }
                    </div>

                    <div class="book-card-body">
                        <h3 class="book-card-title">@libro.Titulo</h3>
                        <p class="book-card-author">
                            <i class="bi bi-person-fill"></i> @libro.Autor
                        </p>
                        <p class="book-card-description">@libro.Descripcion</p>

                        <div class="book-card-footer">
                            <div>
                                <div class="book-card-price">$@libro.Precio.ToString("N2")</div>
                                <div class="book-card-stock @(libro.Stock < 5 ? "low-stock" : "")">
                                    <i class="bi bi-box-seam"></i> Stock: @libro.Stock
                                </div>
                            </div>
                            <a asp-action="Details" asp-route-id="@libro.Id" class="btn btn-outline-gold">
                                <i class="bi bi-eye"></i> Ver
                            </a>
                        </div>

                        @if (esPropio)
                        {
                            <div class="d-flex gap-2 mt-2">
                                <a asp-action="Edit" asp-route-id="@libro.Id" class="btn btn-sm btn-warning flex-grow-1">
                                    <i class="bi bi-pencil"></i> Editar
                                </a>
                                <a asp-action="Delete" asp-route-id="@libro.Id" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        }
                    </div>

                    <div class="card-footer">
                        <div class="d-flex gap-2 w-100">
                            @* ✅ Botón Añadir al Carrito (solo si hay stock y no es propio) *@
                            @if (!esPropio && libro.Stock > 0 && !string.IsNullOrEmpty(usuarioActualId))
                            {
                                <form asp-controller="Carrito" asp-action="AgregarAlCarrito" method="post" class="flex-grow-1">
                                    <input type="hidden" name="libroId" value="@libro.Id" />
                                    <input type="hidden" name="cantidad" value="1" />
                                    <button type="submit" class="btn btn-primary btn-sm w-100">
                                        <i class="bi bi-cart-plus-fill"></i> Añadir al Carrito
                                    </button>
                                </form>
                            }
                            else if (libro.Stock == 0)
                            {
                                <button class="btn btn-secondary btn-sm flex-grow-1" disabled>
                                    <i class="bi bi-x-circle"></i> Agotado
                                </button>
                            }
                            else if (esPropio)
                            {
                                <span class="btn btn-outline-secondary btn-sm flex-grow-1" style="cursor: not-allowed;">
                                    <i class="bi bi-info-circle"></i> Tu libro
                                </span>
                            }
                            else
                            {
                                <a asp-controller="Auth" asp-action="Login" 
                                   class="btn btn-primary btn-sm flex-grow-1">
                                    <i class="bi bi-box-arrow-in-right"></i> Login para comprar
                                </a>
                            }
                            
                            @* ✅ Chat (solo si no es propio y está logueado) *@
                            @if (!esPropio && !string.IsNullOrEmpty(usuarioActualId))
                            {
                                <a asp-controller="Chat" 
                                   asp-action="IniciarChat" 
                                   asp-route-usuarioId="@libro.UsuarioId"
                                   asp-route-libroId="@libro.Id"
                                   class="btn btn-outline-primary btn-sm" 
                                   title="Contactar al vendedor">
                                    <i class="bi bi-chat-fill"></i>
                                </a>
                            }
                            
                            @* ✅ Favoritos (solo si está logueado) *@
                            @if (!string.IsNullOrEmpty(usuarioActualId))
                            {
                                <a asp-controller="Favorito" asp-action="Agregar" asp-route-libroId="@libro.Id" 
                                   class="btn btn-outline-danger btn-sm" 
                                   title="Agregar a favoritos">
                                    <i class="bi bi-heart"></i>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            <i class="bi bi-info-circle" style="font-size: 2rem;"></i>
            <p class="mb-0 mt-2">No hay libros disponibles en este momento.</p>
        </div>
    }
</div>
