@model BookCloud.Models.Libro

@{
    ViewData["Title"] = "Crear Libro";
}

<style>
    .create-wrapper {
        max-width: 900px;
        margin: 2rem auto;
        padding: 0 1rem;
    }

    .create-card {
        background: var(--verde-card);
        border: 2px solid var(--dorado);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.5);
    }

    .create-header {
        background: linear-gradient(135deg, var(--dorado) 0%, #B8954F 100%);
        color: var(--verde-fondo);
        padding: 2rem;
        text-align: center;
        border-bottom: 2px solid rgba(198, 167, 94, 0.3);
    }

    .create-header i {
        font-size: 3rem;
        margin-bottom: 0.5rem;
        display: block;
    }

    .create-header h2 {
        color: var(--verde-fondo);
        font-weight: 800;
        margin: 0;
    }

    .create-body {
        padding: 2.5rem;
    }

    .image-preview-container {
        text-align: center;
        margin-bottom: 2rem;
        padding: 2rem;
        background: rgba(198, 167, 94, 0.05);
        border-radius: 12px;
        border: 2px dashed var(--dorado);
    }

    #imagePreview {
        max-width: 100%;
        max-height: 300px;
        border-radius: 12px;
        border: 3px solid var(--dorado);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
        display: none;
    }

    .form-label {
        color: var(--dorado);
        font-weight: 600;
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .form-label i {
        font-size: 1.2rem;
    }

    .form-control, .form-select {
        background: rgba(19, 47, 40, 0.5);
        border: 2px solid var(--dorado);
        color: var(--texto-claro);
        border-radius: 12px;
        padding: 0.75rem 1rem;
        transition: all 0.3s ease;
    }

    .form-control:focus, .form-select:focus {
        background: rgba(19, 47, 40, 0.7);
        border-color: var(--dorado-hover);
        box-shadow: 0 0 0 0.2rem rgba(198, 167, 94, 0.25);
        color: var(--texto-claro);
    }

    .form-control::placeholder {
        color: var(--texto-secundario);
    }

    .form-control[type="file"] {
        padding: 0.75rem;
        cursor: pointer;
    }

    .form-control[type="file"]::-webkit-file-upload-button {
        background: linear-gradient(135deg, var(--dorado) 0%, #B8954F 100%);
        border: none;
        color: var(--verde-fondo);
        padding: 0.5rem 1rem;
        border-radius: 8px;
        font-weight: 600;
        margin-right: 1rem;
        cursor: pointer;
    }

    .form-control[type="file"]::-webkit-file-upload-button:hover {
        transform: scale(1.05);
    }

    textarea.form-control {
        resize: vertical;
        min-height: 120px;
    }

    .text-danger {
        color: #FF6B6B !important;
        font-size: 0.875rem;
        margin-top: 0.25rem;
    }

    .text-muted {
        color: var(--texto-secundario) !important;
        font-size: 0.875rem;
        margin-top: 0.25rem;
    }

    .form-check {
        background: rgba(198, 167, 94, 0.1);
        border: 2px solid var(--dorado);
        border-radius: 12px;
        padding: 1rem 1.5rem;
    }

    .form-check-input {
        width: 1.5rem;
        height: 1.5rem;
        border: 2px solid var(--dorado);
        background-color: rgba(19, 47, 40, 0.5);
        cursor: pointer;
    }

    .form-check-input:checked {
        background-color: var(--dorado);
        border-color: var(--dorado);
    }

    .form-check-label {
        color: var(--texto-claro);
        font-weight: 600;
        margin-left: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-publish {
        background: linear-gradient(135deg, var(--dorado) 0%, #B8954F 100%);
        border: none;
        color: var(--verde-fondo);
        padding: 1rem 2rem;
        border-radius: 12px;
        font-weight: 700;
        font-size: 1.1rem;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(198, 167, 94, 0.4);
    }

    .btn-publish:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(198, 167, 94, 0.6);
        color: var(--verde-fondo);
    }

    .btn-cancel {
        background: var(--verde-card);
        border: 2px solid var(--dorado);
        color: var(--dorado);
        padding: 1rem 2rem;
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-cancel:hover {
        background: rgba(198, 167, 94, 0.1);
        color: var(--dorado-hover);
        border-color: var(--dorado-hover);
    }

    .alert-danger {
        background: rgba(239, 68, 68, 0.1);
        border: 2px solid #ef4444;
        color: #ff6b6b;
        border-radius: 12px;
        padding: 1rem;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .create-body {
            padding: 1.5rem;
        }

        .create-header {
            padding: 1.5rem;
        }

        .create-header h2 {
            font-size: 1.5rem;
        }
    }
</style>

<div class="create-wrapper">
    <div class="create-card">
        <div class="create-header">
            <i class="bi bi-book"></i>
            <h2>Publicar Nuevo Libro</h2>
        </div>
        
        <div class="create-body">
            <form asp-action="Create" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <!-- Preview de imagen -->
                <div class="image-preview-container">
                    <img id="imagePreview" 
                         src="/images/upload-placeholder.png" 
                         alt="Preview" />
                    <div id="uploadPlaceholder" style="color: var(--texto-secundario);">
                        <i class="bi bi-image" style="font-size: 3rem; opacity: 0.3;"></i>
                        <p class="mt-2">La vista previa aparecerá aquí</p>
                    </div>
                </div>

                <div class="row g-3">
                    <!-- Foto del libro -->
                    <div class="col-12">
                        <label class="form-label">
                            <i class="bi bi-image"></i> Imagen del libro
                        </label>
                        <input type="file" 
                               name="imagenFile" 
                               class="form-control" 
                               accept="image/*" 
                               onchange="previewImage(event)" 
                               required />
                        <small class="text-muted">Formatos: JPG, PNG, GIF. Tamaño máximo: 5MB</small>
                    </div>

                    <!-- Título -->
                    <div class="col-md-6">
                        <label asp-for="Titulo" class="form-label">
                            <i class="bi bi-book-half"></i> Título
                        </label>
                        <input asp-for="Titulo" class="form-control" placeholder="Ingrese el título del libro" />
                        <span asp-validation-for="Titulo" class="text-danger"></span>
                    </div>

                    <!-- Autor -->
                    <div class="col-md-6">
                        <label asp-for="Autor" class="form-label">
                            <i class="bi bi-person"></i> Autor
                        </label>
                        <input asp-for="Autor" class="form-control" placeholder="Nombre del autor" />
                        <span asp-validation-for="Autor" class="text-danger"></span>
                    </div>

                    <!-- Descripción -->
                    <div class="col-12">
                        <label asp-for="Descripcion" class="form-label">
                            <i class="bi bi-text-paragraph"></i> Descripción
                        </label>
                        <textarea asp-for="Descripcion" 
                                  class="form-control" 
                                  rows="4" 
                                  placeholder="Describe el libro..."></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger"></span>
                    </div>

                    <!-- Precio -->
                    <div class="col-md-4">
                        <label asp-for="Precio" class="form-label">
                            <i class="bi bi-cash-coin"></i> Precio
                        </label>
                        <input asp-for="Precio" 
                               type="number" 
                               step="0.01" 
                               class="form-control" 
                               placeholder="0.00" />
                        <span asp-validation-for="Precio" class="text-danger"></span>
                    </div>

                    <!-- Stock -->
                    <div class="col-md-4">
                        <label asp-for="Stock" class="form-label">
                            <i class="bi bi-box-seam"></i> Stock
                        </label>
                        <input asp-for="Stock" 
                               type="number" 
                               class="form-control" 
                               placeholder="0" />
                        <span asp-validation-for="Stock" class="text-danger"></span>
                    </div>

                    <!-- Fecha de publicación -->
                    <div class="col-md-4">
                        <label asp-for="FechaPublicacion" class="form-label">
                            <i class="bi bi-calendar-event"></i> Fecha de Publicación
                        </label>
                        <input asp-for="FechaPublicacion" 
                               type="date" 
                               class="form-control" />
                        <span asp-validation-for="FechaPublicacion" class="text-danger"></span>
                    </div>

                    <!-- Activo -->
                    <div class="col-12">
                        <div class="form-check">
                            <input class="form-check-input" 
                                   asp-for="Activo" 
                                   type="checkbox" 
                                   checked />
                            <label class="form-check-label">
                                <i class="bi bi-check-circle"></i> Libro activo y visible en el catálogo
                            </label>
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-publish">
                        <i class="bi bi-check-circle"></i> Publicar Libro
                    </button>
                    <a asp-action="Index" class="btn btn-cancel">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        function previewImage(event) {
            const file = event.target.files[0];
            const preview = document.getElementById('imagePreview');
            const placeholder = document.getElementById('uploadPlaceholder');
            
            if (file) {
                // Validar tamaño (5MB)
                if (file.size > 5 * 1024 * 1024) {
                    alert('La imagen es demasiado grande. Tamaño máximo: 5MB');
                    event.target.value = '';
                    return;
                }

                const reader = new FileReader();
                reader.onload = function () {
                    preview.src = reader.result;
                    preview.style.display = "block";
                    if (placeholder) {
                        placeholder.style.display = "none";
                    }
                }
                reader.readAsDataURL(file);
            }
        }
    </script>
}

