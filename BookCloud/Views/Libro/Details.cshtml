@model Libro

@{
    ViewData["Title"] = Model.Titulo;
    var usuarioActualId = Context.Session.GetString("Id");
    var esPropio = Model.UsuarioId.ToString() == usuarioActualId;
}

<style>
    .details-wrapper {
        max-width: 1400px;
        margin: 2rem auto;
        padding: 0 1rem;
    }

    .back-button {
        background: var(--verde-card);
        border: 2px solid var(--dorado);
        color: var(--dorado);
        padding: 0.75rem 1.5rem;
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 2rem;
    }

    .back-button:hover {
        background: var(--dorado);
        color: var(--verde-fondo);
        transform: translateX(-5px);
    }

    .details-card {
        background: var(--verde-card);
        border: 2px solid var(--dorado);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.5);
    }

    .details-grid {
        display: grid;
        grid-template-columns: 400px 1fr;
        gap: 0;
    }

    .details-image-container {
        background: linear-gradient(135deg, rgba(198, 167, 94, 0.1) 0%, rgba(19, 47, 40, 0.2) 100%);
        padding: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border-right: 2px solid var(--dorado);
    }

    .details-image {
        max-width: 100%;
        max-height: 600px;
        object-fit: contain;
        border-radius: 12px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
        border: 3px solid var(--dorado);
    }

    .details-content {
        padding: 2.5rem;
    }

    .details-title {
        color: var(--dorado);
        font-size: 2.5rem;
        font-weight: 800;
        margin-bottom: 0.75rem;
        line-height: 1.2;
    }

    .details-author {
        color: var(--texto-secundario);
        font-size: 1.2rem;
        font-style: italic;
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .details-description {
        color: var(--texto-claro);
        font-size: 1.1rem;
        line-height: 1.8;
        margin-bottom: 2rem;
        padding: 1.5rem;
        background: rgba(19, 47, 40, 0.3);
        border-radius: 12px;
        border-left: 4px solid var(--dorado);
    }

    .details-info-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .info-box {
        background: rgba(198, 167, 94, 0.1);
        border: 2px solid var(--dorado);
        border-radius: 12px;
        padding: 1.25rem;
        text-align: center;
        transition: all 0.3s ease;
    }

    .info-box:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 16px rgba(198, 167, 94, 0.3);
    }

    .info-icon {
        font-size: 2rem;
        color: var(--dorado);
        margin-bottom: 0.5rem;
    }

    .info-label {
        color: var(--texto-secundario);
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.5rem;
    }

    .info-value {
        color: var(--dorado);
        font-size: 1.5rem;
        font-weight: 800;
    }

    .action-section {
        background: rgba(19, 47, 40, 0.3);
        border-radius: 12px;
        padding: 1.5rem;
        margin-top: 2rem;
    }

    .quantity-input {
        background: rgba(19, 47, 40, 0.5);
        border: 2px solid var(--dorado);
        color: var(--texto-claro);
        border-radius: 8px;
        padding: 0.5rem;
        width: 80px;
        text-align: center;
        font-weight: 600;
    }

    .btn-add-cart {
        background: linear-gradient(135deg, var(--dorado) 0%, #B8954F 100%);
        border: none;
        color: var(--verde-fondo);
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 700;
        transition: all 0.3s ease;
    }

    .btn-add-cart:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(198, 167, 94, 0.4);
        color: var(--verde-fondo);
    }

    .btn-favorite {
        background: rgba(239, 68, 68, 0.1);
        border: 2px solid #ef4444;
        color: #ef4444;
        padding: 0.75rem;
        border-radius: 8px;
        transition: all 0.3s ease;
        width: 50px;
    }

    .btn-favorite:hover {
        background: #ef4444;
        color: white;
        transform: scale(1.1);
    }

    .btn-contact {
        background: transparent;
        border: 2px solid var(--dorado);
        color: var(--dorado);
        padding: 1rem;
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.3s ease;
        margin-top: 1rem;
    }

    .btn-contact:hover {
        background: var(--dorado);
        color: var(--verde-fondo);
    }

    .btn-edit {
        background: #f59e0b;
        border: none;
        color: var(--verde-fondo);
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
    }

    .btn-delete {
        background: #ef4444;
        border: none;
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
    }

    .divider {
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--dorado), transparent);
        margin: 2rem 0;
    }

    /* Responsive */
    @@media (max-width: 992px) {
        .details-grid {
            grid-template-columns: 1fr;
        }

        .details-image-container {
            border-right: none;
            border-bottom: 2px solid var(--dorado);
            padding: 1.5rem;
        }

        .details-image {
            max-height: 400px;
        }

        .details-content {
            padding: 1.5rem;
        }

        .details-title {
            font-size: 2rem;
        }

        .details-info-grid {
            grid-template-columns: 1fr;
            gap: 1rem;
        }
    }
</style>

<div class="details-wrapper">
    <a asp-action="Index" class="back-button">
        <i class="bi bi-arrow-left"></i> Volver al catálogo
    </a>

    <div class="details-card">
        <div class="details-grid">
            <!-- Columna de la imagen -->
            <div class="details-image-container">
                <img src="~/imagenes/Libros/@Model.Foto"
                     alt="@Model.Titulo" 
                     class="details-image" />
            </div>

            <!-- Columna de contenido -->
            <div class="details-content">
                <h1 class="details-title">@Model.Titulo</h1>
                <p class="details-author">
                    <i class="bi bi-person-fill"></i> por @Model.Autor
                </p>

                <p class="details-description">@Model.Descripcion</p>

                <!-- Grid de información -->
                <div class="details-info-grid">
                    <div class="info-box">
                        <div class="info-icon">
                            <i class="bi bi-cash-coin"></i>
                        </div>
                        <div class="info-label">Precio</div>
                        <div class="info-value">$@Model.Precio.ToString("N2")</div>
                    </div>

                    <div class="info-box">
                        <div class="info-icon">
                            <i class="bi bi-box-seam"></i>
                        </div>
                        <div class="info-label">Stock</div>
                        <div class="info-value">@Model.Stock</div>
                    </div>

                    <div class="info-box">
                        <div class="info-icon">
                            <i class="bi bi-calendar-event"></i>
                        </div>
                        <div class="info-label">Publicación</div>
                        <div class="info-value" style="font-size: 1.1rem;">
                            @Model.FechaPublicacion.ToString("dd/MM/yyyy")
                        </div>
                    </div>
                </div>

                <!-- Sección de acciones -->
                @if (!esPropio)
                {
                    <div class="action-section">
                        @if (Model.Stock > 0)
                        {
                            <form asp-controller="Carrito" asp-action="AgregarAlCarrito" method="post">
                                <input type="hidden" name="libroId" value="@Model.Id" />
                                <div class="d-flex gap-2 align-items-center">
                                    <input type="number" 
                                           name="cantidad" 
                                           value="1" 
                                           min="1" 
                                           max="@Model.Stock" 
                                           class="quantity-input" />
                                    <button type="submit" class="btn btn-add-cart flex-grow-1">
                                        <i class="bi bi-cart-plus-fill"></i> Añadir al Carrito
                                    </button>
                                    @if (!string.IsNullOrEmpty(usuarioActualId))
                                    {
                                        <a asp-controller="Favorito" asp-action="Agregar" asp-route-libroId="@Model.Id" 
                                           class="btn btn-favorite">
                                            <i class="bi bi-heart-fill"></i>
                                        </a>
                                    }
                                </div>
                            </form>
                        }
                        else
                        {
                            <button class="btn btn-danger w-100" disabled>
                                <i class="bi bi-x-circle"></i> Agotado - No disponible
                            </button>
                        }

                        @if (!string.IsNullOrEmpty(usuarioActualId))
                        {
                            <a asp-controller="Chat" 
                               asp-action="IniciarChat" 
                               asp-route-usuarioId="@Model.UsuarioId"
                               asp-route-libroId="@Model.Id"
                               class="btn btn-contact w-100">
                                <i class="bi bi-chat-fill"></i> Contactar al Vendedor
                            </a>
                        }
                    </div>
                }
                else
                {
                    <div class="divider"></div>
                    <div class="alert alert-info mb-3">
                        <i class="bi bi-info-circle"></i> Este es tu libro
                    </div>
                    <div class="d-flex gap-3">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-edit flex-grow-1">
                            <i class="bi bi-pencil-square"></i> Editar
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-delete">
                            <i class="bi bi-trash"></i> Eliminar
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

