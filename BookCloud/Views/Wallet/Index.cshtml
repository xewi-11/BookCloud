@model WalletViewModel

@{
    ViewData["Title"] = "Mi Wallet";
}

<div class="container wallet-container">
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <h1 class="section-title">
        <i class="bi bi-wallet2"></i> Mi Wallet
    </h1>

    <!-- Tarjeta de saldo principal -->
    <div class="row mb-4">
        <div class="col-lg-8 mx-auto">
            <div class="wallet-balance-card">
                <div class="balance-header">
                    <i class="bi bi-cash-stack"></i>
                    <span>Saldo Disponible</span>
                </div>
                <div class="balance-amount">
                    $@Model.SaldoActual.ToString("N2")
                </div>
                <div class="balance-footer">
                    <div class="balance-stat">
                        <i class="bi bi-arrow-up-circle text-success"></i>
                        <div>
                            <small>Ingresos</small>
                            <div class="stat-value text-success">$@Model.TotalIngresos</div>
                        </div>
                    </div>
                    <div class="balance-stat">
                        <i class="bi bi-arrow-down-circle text-danger"></i>
                        <div>
                            <small>Gastos</small>
                            <div class="stat-value text-danger">$@Model.TotalGastos</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Botón de recarga -->
    <div class="row mb-4">
        <div class="col-lg-8 mx-auto">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-credit-card"></i> Recargar Saldo
                </div>
                <div class="card-body">
                    <p class="text-muted mb-3">
                        <i class="bi bi-shield-check"></i> Pago seguro mediante tarjeta de crédito o débito
                    </p>
                    <button type="button" class="btn btn-primary w-100" data-bs-toggle="modal" data-bs-target="#modalRecarga">
                        <i class="bi bi-wallet2"></i> Recargar con Tarjeta
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal de recarga con tarjeta -->
    <div class="modal fade" id="modalRecarga" tabindex="-1" aria-labelledby="modalRecargaLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background: var(--verde-card); border: 2px solid var(--dorado);">
                <div class="modal-header border-bottom border-secondary">
                    <h5 class="modal-title" id="modalRecargaLabel">
                        <i class="bi bi-credit-card-2-front"></i> Recargar Wallet
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="RecargarSaldo" method="post" id="formRecarga">
                    <div class="modal-body">
                        <!-- Monto -->
                        <div class="mb-3">
                            <label for="monto" class="form-label">
                                <i class="bi bi-cash-coin"></i> Monto a recargar
                            </label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input type="number" 
                                       class="form-control" 
                                       id="monto" 
                                       name="Monto" 
                                       placeholder="0.00" 
                                       step="0.01" 
                                       min="1" 
                                       max="10000" 
                                       required>
                            </div>
                            <small class="text-muted">Mínimo: $1.00 - Máximo: $10,000.00</small>
                        </div>

                        <hr class="border-secondary">

                        <!-- Número de tarjeta -->
                        <div class="mb-3">
                            <label for="numeroTarjeta" class="form-label">
                                <i class="bi bi-credit-card"></i> Número de tarjeta
                            </label>
                            <input type="text" 
                                   class="form-control" 
                                   id="numeroTarjeta" 
                                   name="NumeroTarjeta" 
                                   placeholder="1234 5678 9012 3456" 
                                   maxlength="19"
                                   required>
                            <small class="text-muted">Ingresa los 16 dígitos de tu tarjeta</small>
                        </div>

                        <!-- Nombre del titular -->
                        <div class="mb-3">
                            <label for="nombreTitular" class="form-label">
                                <i class="bi bi-person"></i> Nombre del titular
                            </label>
                            <input type="text" 
                                   class="form-control text-uppercase" 
                                   id="nombreTitular" 
                                   name="NombreTitular" 
                                   placeholder="JUAN PEREZ" 
                                   required>
                        </div>

                        <!-- Fecha de vencimiento y CVV -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="fechaVencimiento" class="form-label">
                                    <i class="bi bi-calendar-event"></i> Vencimiento
                                </label>
                                <input type="text" 
                                       class="form-control" 
                                       id="fechaVencimiento" 
                                       name="FechaVencimiento" 
                                       placeholder="MM/AA" 
                                       maxlength="5"
                                       required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="cvv" class="form-label">
                                    <i class="bi bi-shield-lock"></i> CVV
                                </label>
                                <input type="text" 
                                       class="form-control" 
                                       id="cvv" 
                                       name="CVV" 
                                       placeholder="123" 
                                       maxlength="4"
                                       required>
                            </div>
                        </div>

                        <div class="alert alert-info mb-0">
                            <i class="bi bi-info-circle"></i> 
                            <small>Tus datos están protegidos con encriptación SSL</small>
                        </div>
                    </div>
                    <div class="modal-footer border-top border-secondary">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            <i class="bi bi-x-circle"></i> Cancelar
                        </button>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> Confirmar Recarga
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Historial de movimientos -->
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-clock-history"></i> Historial de Movimientos
                </div>
                <div class="card-body p-0">
                    @if (Model.Movimientos != null && Model.Movimientos.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var movimiento in Model.Movimientos)
                            {
                                <div class="list-group-item movement-item">
                                    <div class="movement-icon @(movimiento.Tipo == "Ingreso" ? "income" : "expense")">
                                        <i class="bi @(movimiento.Tipo == "Ingreso" ? "bi-arrow-down-circle" : "bi-arrow-up-circle")"></i>
                                    </div>
                                    <div class="movement-details">
                                        <div class="movement-description">
                                            @movimiento.Descripcion
                                        </div>
                                        <div class="movement-date">
                                            <i class="bi bi-calendar3"></i> 
                                            @movimiento.Fecha.ToString("dd/MM/yyyy HH:mm")
                                        </div>
                                        @if (movimiento.PedidoId.HasValue)
                                        {
                                            <div class="movement-reference">
                                                <i class="bi bi-receipt"></i> Pedido #@movimiento.PedidoId
                                            </div>
                                        }
                                    </div>
                                    <div class="movement-amount @(movimiento.Tipo == "Ingreso" ? "income" : "expense")">
                                        @(movimiento.Tipo == "Ingreso" ? "+" : "-")$@movimiento.Monto.ToString("N2")
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-inbox" style="font-size: 3rem; color: var(--texto-secundario);"></i>
                            <p class="text-muted mt-3">No hay movimientos registrados</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Formatear número de tarjeta con espacios
        document.getElementById('numeroTarjeta').addEventListener('input', function (e) {
            let value = e.target.value.replace(/\s/g, '').replace(/\D/g, '');
            let formattedValue = value.match(/.{1,4}/g)?.join(' ') || value;
            e.target.value = formattedValue;
        });

        // Formatear fecha de vencimiento MM/AA
        document.getElementById('fechaVencimiento').addEventListener('input', function (e) {
            let value = e.target.value.replace(/\D/g, '');
            if (value.length >= 2) {
                value = value.slice(0, 2) + '/' + value.slice(2, 4);
            }
            e.target.value = value;
        });

        // Solo números en CVV
        document.getElementById('cvv').addEventListener('input', function (e) {
            e.target.value = e.target.value.replace(/\D/g, '');
        });

        // Mayúsculas en nombre del titular
        document.getElementById('nombreTitular').addEventListener('input', function (e) {
            e.target.value = e.target.value.toUpperCase();
        });

        // Validación antes de enviar
        document.getElementById('formRecarga').addEventListener('submit', function(e) {
            const monto = parseFloat(document.getElementById('monto').value);
            if (monto < 1 || monto > 10000) {
                e.preventDefault();
                alert('El monto debe estar entre $1 y $10,000');
                return false;
            }

            const numeroTarjeta = document.getElementById('numeroTarjeta').value.replace(/\s/g, '');
            if (numeroTarjeta.length < 13 || numeroTarjeta.length > 19) {
                e.preventDefault();
                alert('El número de tarjeta no es válido');
                return false;
            }
        });
    </script>
}