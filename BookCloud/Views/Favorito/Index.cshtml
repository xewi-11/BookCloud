@model List<BookCloud.Models.Libro>

@{
    ViewData["Title"] = "Mis Favoritos";
}

<div class="container mt-4">
    <h2>📚 Mis Libros Favoritos</h2>
    <hr />

    @if (ViewData["MENSAJE"] != null)
    {
        <div class="alert alert-info">
            @ViewData["MENSAJE"]
        </div>
    }

    @if (TempData["MENSAJE"] != null)
    {
        <div class="alert alert-success">
            @TempData["MENSAJE"]
        </div>
    }

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-warning">
            <p>No tienes libros en favoritos. ¡Explora nuestro catálogo y agrega tus libros preferidos!</p>
            <a asp-controller="Libro" asp-action="Index" class="btn btn-primary">Ver Libros</a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var libro in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        @if (!string.IsNullOrEmpty(libro.Foto))
                        {
                            <img src="@libro.Foto" class="card-img-top" alt="@libro.Titulo" style="height: 300px; object-fit: cover;">
                        }
                        else
                        {
                            <img src="~/images/libro-default.jpg" class="card-img-top" alt="@libro.Titulo" style="height: 300px; object-fit: cover;">
                        }
                        <div class="card-body">
                            <h5 class="card-title">@libro.Titulo</h5>
                            <p class="card-text"><strong>Autor:</strong> @libro.Autor</p>
                            <p class="card-text"><strong>Precio:</strong> $@libro.Precio.ToString("N2")</p>
                            <p class="card-text text-muted">@(libro.Descripcion)...</p>
                        </div>
                        <div class="card-footer">
                            <a asp-controller="Libro" asp-action="Details" asp-route-id="@libro.Id" class="btn btn-primary btn-sm">Ver Detalles</a>
                            <a asp-controller="Favorito" asp-action="Index" asp-route-ideliminar="@libro.Id" class="btn btn-danger btn-sm">
                                <i class="bi bi-heart-fill"></i> Quitar
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="mt-3">
        <a asp-controller="Libro" asp-action="Index" class="btn btn-secondary">Volver al Catálogo</a>
    </div>
</div>